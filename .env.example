# docker compose environment — copy to .env, then `docker compose up --build`.
# The compose file reads each of these; missing required keys (marked :?) will
# fail fast with a clear error.

# Postgres — password for the local db container (db_data volume survives restarts).
POSTGRES_PASSWORD=medai

# Required to boot the api service.
OPENROUTER_API_KEY=
OPENAI_API_KEY=   # tracing only
# Groq powers the free tier (GPT-OSS-120B). Get a key at https://console.groq.com/keys
GROQ_API_KEY=

# Clerk — set these to enable authentication. Leave blank for anonymous dev.
CLERK_ISSUER=
CLERK_SECRET_KEY=
CLERK_AUTHORIZED_PARTIES=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Email (optional — Pro features).
RESEND_API_KEY=
RESEND_FROM_EMAIL=
ONCALL_DOCTOR_EMAIL=

# Restrict API cross-origin access. The web container proxies /api/* so the
# browser only ever hits this service through http://localhost:3000 anyway.
ALLOWED_ORIGINS=http://localhost:3000

# Optional — override the transcription/TTS provider.
SPEECH_PROVIDER=openrouter

# Opaque token used to gate the /feedback admin viewer.
FEEDBACK_SECRET=
