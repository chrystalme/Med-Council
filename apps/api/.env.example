# ─── LLM inference ────────────────────────────────────────────────
# OpenRouter key for model inference (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-...

# OpenAI key for Agents SDK tracing only (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-proj-...

# ─── Auth (Clerk) ─────────────────────────────────────────────────
# Secret key from dashboard.clerk.com (Developers → API keys)
CLERK_SECRET_KEY=sk_test_...

# Clerk JWKS issuer URL (dashboard.clerk.com → JWT templates or Frontend API URL)
# Usually: https://{your-frontend-api}.clerk.accounts.dev
CLERK_ISSUER=https://your-app.clerk.accounts.dev

# ─── Optional integrations ────────────────────────────────────────
# PubMed fallback search works without a key; these are only if you
# want to raise request limits.
# NCBI_API_KEY=

# Pushover (legacy notification channel — will be replaced by Resend)
PUSHOVER_USER=
PUSHOVER_TOKEN=

# Admin-only feedback viewer
FEEDBACK_TOKEN=change-me

# ─── Case persistence (Step 3) ───────────────────────────────────
# Uses the same SQLite file as feedback (apps/api/feedback.db locally, /tmp on Vercel).

# ─── On-call escalation (Step 4) ────────────────────────────────
# When consensus urgency is emergency/stat/urgent/etc., sends one email via Resend.
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=MedAI <onboarding@resend.dev>
# ONCALL_DOCTOR_EMAIL=doctor@example.com

# ─── Rate limiting (Step 5) ───────────────────────────────────────
# RATE_LIMIT_ENABLED=1
# RATE_LIMIT_MAX_PER_MINUTE=120

# Postgres (Neon / Cloud SQL) — later migration from SQLite
# DATABASE_URL=postgres://user:pass@host/db
