# ─── Python ──────────────────────────────────────────────────────
__pycache__/
*.py[cod]
.venv/
# Pin API Python for uv/CI; allow apps/api/.python-version
.python-version
!apps/api/.python-version

# ─── Env & secrets ───────────────────────────────────────────────
.env
.env.*
!.env.example

# ─── Local-only artefacts ────────────────────────────────────────
feedback.db
apps/api/feedback.db
.claude/

# ─── Deployment caches ───────────────────────────────────────────
.vercel/
.gcloudignore

# ─── Clerk local keyless config ──────────────────────────────────
.clerk/
apps/web/.clerk/

# ─── Python utilities (local-only) ───────────────────────────────
docs/
scripts/
apps/api/docs/
# The blanket `scripts/` above matches any `scripts/` directory in the tree,
# including `apps/api/scripts/`. Un-ignore that directory so team-facing
# helpers (get_env.sh, migrate_sqlite_to_postgres.py) can live there, then
# ignore the local-only demo/gif generators individually.
!apps/api/scripts/
apps/api/scripts/generate_demo_ui_gif.py
apps/api/scripts/generate_pipeline_gif.py
apps/api/scripts/__pycache__/

# ─── Node / Next.js ──────────────────────────────────────────────
node_modules/
.pnpm-store/
.next/
out/
build/
.turbo/

# ─── Logs & OS ───────────────────────────────────────────────────
*.log
.DS_Store
Thumbs.db

# ─── Editor / IDE ────────────────────────────────────────────────
.cursor/
.idea/
.vscode/
!.vscode/extensions.json

# ─── TypeScript / testing ────────────────────────────────────────
*.tsbuildinfo
coverage/
